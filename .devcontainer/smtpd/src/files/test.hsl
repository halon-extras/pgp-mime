import $mime from "txt!test.eml";
import $pubkeyring from "txt!test.pub.asc";
import $privkeyring from "txt!test.priv.asc";
import { pgp_is_signed_mime, pgp_sign_mime, pgp_verify_mime, pgp_is_encrypted_mime, pgp_encrypt_mime, pgp_decrypt_mime } from "file://pgp-mime.hsl";

// Test 1 (Sign + Verify)
$mail = MailMessage::String($mime);
$expect = $mail->getBody();
pgp_sign_mime($mail, [$privkeyring], ["profile" => "default"]);
$signed = MailMessage::String($mail->toString());
pgp_verify_mime($signed, [$pubkeyring], ["profile" => "default"]);
$verified = MailMessage::String($signed->toString());
$result = $verified->getBody();
if ($expect !== $result)
    throw Exception("Test 1 (Sign + Verify): FAILED\nRESULT($result)\nEXPECT($expect)");
echo "Test 1 (Sign + Verify):\t\t\t\tOK";

// Test 2 (Sign + Encrypt & Decrypt + Verify)
$mail = MailMessage::String($mime);
$expect = $mail->getBody();
pgp_encrypt_mime($mail, [$pubkeyring], [$privkeyring], ["profile" => "default"]);
$encrypted = MailMessage::String($mail->toString());
pgp_decrypt_mime($encrypted, [$privkeyring], [$pubkeyring], ["profile" => "default"]);
$decrypted = MailMessage::String($encrypted->toString());
$result = $decrypted->getBody();
if ($expect !== $result)
    throw Exception("Test 2 (Sign + Encrypt & Decrypt + Verify): FAILED\nRESULT($result)\nEXPECT($expect)");
echo "Test 2 (Sign + Encrypt & Decrypt + Verify):\tOK";

// Test 3 (Verify)
$mail = MailMessage::String($mime);
$expect = ["result"=>true,"signers"=>[0=>''-----BEGIN PGP PUBLIC KEY BLOCK-----

xjMEaYRHMxYJKwYBBAHaRw8BAQdAeys1HObh1T/52MyemnXSSBKGcGroexC+HvTf
D+83WeTNH0phbmUgRG9lIDxqYW5lLmRvZUBleGFtcGxlLmNvbT7CkwQTFgoAOxYh
BLLciu3Pt1+M33uRHPGl+Kn/XCQaBQJphEczAhsDBQsJCAcCAiICBhUKCQgLAgQW
AgMBAh4HAheAAAoJEPGl+Kn/XCQazm4A/A8hXrCwRnTdAh25IruJtH6SNnljznQX
M3JUg6PYx61MAQCo9yo50vjAUXE7YDLSpoF8imtXxaurEX/l2Yyvc84bAs44BGmE
RzMSCisGAQQBl1UBBQEBB0C3hYG+Scszkyw83DkUD9jKwFJoGl7GR0MT8ddAOd+y
XwMBCAfCeAQYFgoAIBYhBLLciu3Pt1+M33uRHPGl+Kn/XCQaBQJphEczAhsMAAoJ
EPGl+Kn/XCQaCRkA/3LIxSlDRZ638mCSsG8cLllEElfGOjTbnEvuJ8AA/w95AP0Z
MYLXiY/jaRdbAiK/F7X/cYcgtxYAA8hEptD3Cu3+Dg==
=cAcn
-----END PGP PUBLIC KEY BLOCK-----'']];
pgp_sign_mime($mail, [$privkeyring], ["profile" => "default"]);
$signed = MailMessage::String($mail->toString());
$result = pgp_verify_mime($signed, [$pubkeyring], ["profile" => "default"]);
if (json_encode($result) !== json_encode($expect))
    throw Exception("Test 3 (Verify): FAILED\nRESULT($result)\nEXPECT($expect)");
echo "Test 3 (Verify):\t\t\t\tOK";

// Test 4 (Decrypt + Verify)
$mail = MailMessage::String($mime);
$expect = ["result"=>true,"signers"=>[0=>''-----BEGIN PGP PUBLIC KEY BLOCK-----

xjMEaYRHMxYJKwYBBAHaRw8BAQdAeys1HObh1T/52MyemnXSSBKGcGroexC+HvTf
D+83WeTNH0phbmUgRG9lIDxqYW5lLmRvZUBleGFtcGxlLmNvbT7CkwQTFgoAOxYh
BLLciu3Pt1+M33uRHPGl+Kn/XCQaBQJphEczAhsDBQsJCAcCAiICBhUKCQgLAgQW
AgMBAh4HAheAAAoJEPGl+Kn/XCQazm4A/A8hXrCwRnTdAh25IruJtH6SNnljznQX
M3JUg6PYx61MAQCo9yo50vjAUXE7YDLSpoF8imtXxaurEX/l2Yyvc84bAs44BGmE
RzMSCisGAQQBl1UBBQEBB0C3hYG+Scszkyw83DkUD9jKwFJoGl7GR0MT8ddAOd+y
XwMBCAfCeAQYFgoAIBYhBLLciu3Pt1+M33uRHPGl+Kn/XCQaBQJphEczAhsMAAoJ
EPGl+Kn/XCQaCRkA/3LIxSlDRZ638mCSsG8cLllEElfGOjTbnEvuJ8AA/w95AP0Z
MYLXiY/jaRdbAiK/F7X/cYcgtxYAA8hEptD3Cu3+Dg==
=cAcn
-----END PGP PUBLIC KEY BLOCK-----'']];
pgp_encrypt_mime($mail, [$pubkeyring], [$privkeyring], ["profile" => "default"]);
$encrypted = MailMessage::String($mail->toString());
$result = pgp_decrypt_mime($encrypted, [$privkeyring], [$pubkeyring], ["profile" => "default"]);
if (json_encode($result) !== json_encode($expect))
    throw Exception("Test 4 (Decrypt + Verify): FAILED\nRESULT($result)\nEXPECT($expect)");
echo "Test 4 (Decrypt + Verify):\t\t\tOK";

// Test 5 (Decrypt)
$mail = MailMessage::String($mime);
$expect = ["result"=>true];
pgp_encrypt_mime($mail, [$pubkeyring], [$privkeyring], ["profile" => "default"]);
$encrypted = MailMessage::String($mail->toString());
$result = pgp_decrypt_mime($encrypted, [$privkeyring], none, ["profile" => "default"]);
if (json_encode($result) !== json_encode($expect))
    throw Exception("Test 5 (Decrypt): FAILED\nRESULT($result)\nEXPECT($expect)");
echo "Test 5 (Decrypt):\t\t\t\tOK";

// Test 6 (Is signed)
$mail = MailMessage::String($mime);
$expect = true;
pgp_sign_mime($mail, [$privkeyring], ["profile" => "default"]);
$signed = MailMessage::String($mail->toString());
$result = pgp_is_signed_mime($signed);
if (json_encode($result) !== json_encode($expect))
    throw Exception("Test 7 (Is signed): FAILED\nRESULT($result)\nEXPECT($expect)");
echo "Test 7 (Is signed):\t\t\t\tOK";

// Test 7 (Is encrypted)
$mail = MailMessage::String($mime);
$expect = true;
pgp_encrypt_mime($mail, [$pubkeyring], [$privkeyring], ["profile" => "default"]);
$encrypted = MailMessage::String($mail->toString());
$result = pgp_is_encrypted_mime($encrypted);
if (json_encode($result) !== json_encode($expect))
    throw Exception("Test 7 (Is encrypted): FAILED\nRESULT($result)\nEXPECT($expect)");
echo "Test 7 (Is encrypted):\t\t\t\tOK";

// Test 8 (Is not signed)
$mail = MailMessage::String($mime);
$expect = false;
$result = pgp_is_signed_mime($mail);
if (json_encode($result) !== json_encode($expect))
    throw Exception("Test 8 (Is not signed): FAILED\nRESULT($result)\nEXPECT($expect)");
echo "Test 8 (Is not signed):\t\t\t\tOK";

// Test 9 (Is not encrypted)
$mail = MailMessage::String($mime);
$expect = false;
$result = pgp_is_encrypted_mime($mail);
if (json_encode($result) !== json_encode($expect))
    throw Exception("Test 9 (Is not encrypted): FAILED\nRESULT($result)\nEXPECT($expect)");
echo "Test 9 (Is not encrypted):\t\t\tOK";
